{
  "name": "ts-simple-boilderplate",
  "version": "0.0.1",
  "description": "Simple boilerplate for @sota1235",
  "main": "dist/index.js",
  "type": "module",
  "dependencies": {
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@sota1235/eslint-config": "5.0.5",
    "eslint": "9.37.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "prettier": "3.6.2",
    "ts-loader": "9.5.4",
    "typescript-eslint": "8.46.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.publish.json",
    "build:publish": "tsc -p ./tsconfig.publish.json",
    "watch": "tsc --watch",
    "fix": "npm run prettier && npm run eslint:fix",
    "lint": "eslint",
    "eslint:fix": "eslint --fix",
    "prettier": "prettier './src/**/*.ts' --write",
    "test": "vitest",
    "test:ci": "vitest",
    "prepare": "husky",
    "update-checksum": "aqua update-checksum -prune"
  },
  "keywords": [],
  "author": "@sota1235",
  "license": "MIT",
  "packageManager": "pnpm@10.18.3+sha512.bbd16e6d7286fd7e01f6b3c0b3c932cda2965c06a908328f74663f10a9aea51f1129eea615134bf992831b009eabe167ecb7008b597f40ff9bc75946aadfb08d"
}
