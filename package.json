{
  "name": "ts-simple-boilderplate",
  "version": "0.0.1",
  "description": "Simple boilerplate for @sota1235",
  "main": "dist/index.js",
  "type": "module",
  "dependencies": {
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@sota1235/eslint-config": "5.0.1",
    "eslint": "9.14.0",
    "husky": "9.1.6",
    "lint-staged": "15.2.10",
    "prettier": "3.3.3",
    "ts-loader": "9.5.1",
    "typescript-eslint": "8.13.0",
    "vitest": "^2.1.6"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.publish.json",
    "build:publish": "tsc -p ./tsconfig.publish.json",
    "watch": "tsc --watch",
    "fix": "npm run prettier && npm run eslint:fix",
    "lint": "eslint",
    "eslint:fix": "eslint --fix",
    "prettier": "prettier './src/**/*.ts' --write",
    "test": "vitest",
    "test:ci": "vitest",
    "prepare": "husky",
    "update-checksum": "aqua update-checksum -prune"
  },
  "keywords": [],
  "author": "@sota1235",
  "license": "MIT",
  "packageManager": "pnpm@9.15.6+sha512.139cab068fdf0b751268179ac5f909b5be72afb4a75c513d1905d151befc8977b593d3cf8671ed83d4d6637c5c94b98ffbce108125de4a5a27a31233601a99de"
}
