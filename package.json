{
  "name": "ts-simple-boilderplate",
  "version": "0.0.1",
  "description": "Simple boilerplate for @sota1235",
  "main": "dist/index.js",
  "type": "module",
  "dependencies": {
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@sota1235/eslint-config": "5.0.5",
    "eslint": "9.38.0",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "prettier": "3.6.2",
    "ts-loader": "9.5.4",
    "typescript-eslint": "8.46.2",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.publish.json",
    "build:publish": "tsc -p ./tsconfig.publish.json",
    "watch": "tsc --watch",
    "fix": "npm run prettier && npm run eslint:fix",
    "lint": "eslint",
    "eslint:fix": "eslint --fix",
    "prettier": "prettier './src/**/*.ts' --write",
    "test": "vitest",
    "test:ci": "vitest",
    "prepare": "husky",
    "update-checksum": "aqua update-checksum -prune"
  },
  "keywords": [],
  "author": "@sota1235",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0+sha512.01ff8ae71b4419903b65c60fb2dc9d34cf8bb6e06d03bde112ef38f7a34d6904c424ba66bea5cdcf12890230bf39f9580473140ed9c946fef328b6e5238a345a"
}
